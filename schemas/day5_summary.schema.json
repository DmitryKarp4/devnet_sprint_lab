{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Day 5 Summary Schema",
  "type": "object",
  "required": ["schema_version", "student", "yang", "webex", "pt", "validation_passed"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["5.0"] },
    "student": {
      "type": "object",
      "required": ["token_hash8", "name", "group"],
      "properties": {
        "token_hash8": { "type": "string", "pattern": "^[a-f0-9]{8}$" },
        "name": { "type": "string" },
        "group": { "type": "string" }
      }
    },
    "yang": {
      "type": "object",
      "required": ["ok", "has_interfaces_node"],
      "properties": {
        "ok": { "type": "boolean" },
        "has_interfaces_node": { "type": "boolean" }
      }
    },
    "webex": {
      "type": "object",
      "required": ["ok", "room_title_contains_hash8"],
      "properties": {
        "ok": { "type": "boolean" },
        "room_title_contains_hash8": { "type": "boolean" }
      }
    },
    "pt": {
      "type": "object",
      "required": ["ok", "empty_ticket_seen"],
      "properties": {
        "ok": { "type": "boolean" },
        "empty_ticket_seen": { "type": "boolean" }
      }
    },
    "validation_passed": { "type": "boolean" }
  }
}
